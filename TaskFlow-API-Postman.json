{
  "info": {
    "_postman_id": "taskflow-api-collection",
    "name": "TaskFlow API",
    "description": "Complete API collection for TaskFlow - Task Management REST API with Role-Based Access Control, JWT Authentication, and Redis Caching",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"securePassword123\",\n  \"confirmPassword\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Register a new user with name, email, and password"
          },
          "response": []
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login with email and password, returns JWT token"
          },
          "response": []
        },
        {
          "name": "Logout User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Logout user (requires valid JWT token)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get All Tasks (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks"]
            },
            "description": "Retrieve all tasks (Admin only) - cached for 60 seconds"
          },
          "response": []
        },
        {
          "name": "Get My Tasks (User)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/my",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "my"]
            },
            "description": "Retrieve only assigned tasks for current user"
          },
          "response": []
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", ":id"]
            },
            "description": "Retrieve a specific task by ID"
          },
          "response": []
        },
        {
          "name": "Create Task (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implement user authentication\",\n  \"description\": \"Setup JWT-based authentication with bcrypt password hashing\",\n  \"priority\": \"HIGH\",\n  \"dueDate\": \"2024-12-25T23:59:59Z\",\n  \"assignedTo\": \"<user_id>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks"]
            },
            "description": "Create a new task and assign to a user (Admin only)"
          },
          "response": []
        },
        {
          "name": "Update Task (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implement user authentication\",\n  \"description\": \"Setup JWT-based authentication with bcrypt password hashing\",\n  \"priority\": \"MEDIUM\",\n  \"status\": \"IN_PROGRESS\",\n  \"dueDate\": \"2024-12-25T23:59:59Z\",\n  \"assignedTo\": \"<user_id>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", ":id"]
            },
            "description": "Update task details (Admin only)"
          },
          "response": []
        },
        {
          "name": "Update Task Status (User)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/:id/status",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", ":id", "status"]
            },
            "description": "Update only task status (PENDING → IN_PROGRESS → DONE)"
          },
          "response": []
        },
        {
          "name": "Delete Task (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", ":id"]
            },
            "description": "Delete a task (Admin only)"
          },
          "response": []
        }
      ]
    },
